# Database file path (relative to project root or absolute)
# Default: data/productivity.db
DATABASE_PATH=data/productivity.db

# Node environment
NODE_ENV=production

# Port (optional, default: 3000)
PORT=3737

# ── AI / LLM (optional — enables full NLP chatbot + AI Insights) ─────────────
# Get a free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AI provider: "gemini" (default). Future: openai, anthropic, groq
AI_PROVIDER=gemini

# AI model (default: gemini-1.5-flash — best free tier: 15 RPM, 1M tokens/day)
AI_MODEL=gemini-1.5-flash
